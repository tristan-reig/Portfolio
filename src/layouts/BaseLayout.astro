---
import '../styles/global.css';
const { title } = Astro.props;
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Portfolio — Développeur système & graphisme" />
    <title>{title} · Portfolio</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="alternate icon" href="/Portfolio/favicon.ico" />
  </head>

  <body>
    <div class="layout-wrapper flex flex-col min-h-svh">

      <!-- ── Sticky Header ── -->
      <header
        id="site-header"
        class="sticky top-0 z-40 transition-all duration-300"
      >
        <div class="max-w-5xl mx-auto px-6 md:px-12 h-16 flex items-center justify-between">

          <!-- Logo -->
          <a
            href="/"
            class="font-mono text-sm font-bold tracking-widest uppercase text-accent"
          >
            <span class="text-text-muted">~/</span>portfolio
          </a>

          <!-- Nav -->
          <nav class="hidden md:flex items-center gap-8">
            {[
              { label: "À propos", href: "#about"   },
              { label: "Projets",  href: "#projets"  },
              { label: "Contact",  href: "#contact"  },
            ].map(({ label, href }, i) => (
              <a
                href={href}
                data-section={href.slice(1)}
                class="nav-link font-mono text-xs tracking-widest uppercase text-text-secondary hover:text-accent transition-colors duration-200"
              >
                <span class="text-text-muted mr-1">{String(i + 1).padStart(2,'0')}.</span>
                {label}
              </a>
            ))}
          </nav>

          <!-- GitHub icon link -->
          <a
            href="https://github.com/Skiifig"
            target="_blank"
            rel="noopener"
            class="text-text-secondary hover:text-accent transition-colors duration-200 hidden md:block"
            aria-label="GitHub"
          >
            <i class="fa-brands fa-github text-lg"></i>
          </a>
        </div>
        <!-- Bottom border -->
        <div class="h-px w-full bg-gradient-to-r from-transparent via-border-base to-transparent"></div>
      </header>

      <!-- ── Main ── -->
      <main class="flex-grow max-w-5xl mx-auto w-full px-6 md:px-12">
        <slot />
      </main>

      <!-- ── Footer ── -->
      <footer class="max-w-5xl mx-auto w-full px-6 md:px-12 py-10">
        <div class="h-px mb-8 bg-gradient-to-r from-transparent via-border-base to-transparent"></div>
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <span class="font-mono text-xs text-text-muted">© 2026 — Conçu avec Astro & React</span>
          <div class="flex items-center gap-5">
            <!-- GitHub -->
            <a href="https://github.com/Skiifig" target="_blank" rel="noopener"
               class="text-text-secondary hover:text-accent transition-colors duration-200" aria-label="GitHub">
              <i class="fa-brands fa-github text-lg"></i>
            </a>
            <!-- LinkedIn -->
            <a href="https://linkedin.com/in/tristan-reig" target="_blank" rel="noopener"
               class="text-text-secondary hover:text-accent transition-colors duration-200" aria-label="LinkedIn">
              <i class="fa-brands fa-linkedin text-lg"></i>
            </a>
            <!-- Mail -->
            <a href="mailto:tristan.reig@gmail.com"
               class="text-text-secondary hover:text-accent transition-colors duration-200" aria-label="Mail">
              <i class="fa-solid fa-envelope text-lg"></i>
            </a>
          </div>
        </div>
      </footer>
    </div>

    <script>
      // Header backdrop on scroll
      const header = document.getElementById('site-header') as HTMLElement | null;
      window.addEventListener('scroll', () => {
        if (!header) return;
        if (window.scrollY > 20) {
          header.style.background = 'rgba(6,10,14,0.92)';
          header.style.backdropFilter = 'blur(12px)';
        } else {
          header.style.background = 'transparent';
          header.style.backdropFilter = 'none';
        }
      });

      // Active nav highlight — basé sur la position scroll, pas IntersectionObserver
      const links = document.querySelectorAll<HTMLAnchorElement>('.nav-link');

      function updateActiveLink() {
        const sections = ['about', 'projets', 'contact'];
        const scrollY = window.scrollY + 120;

        // Si on est tout en haut, toujours activer "about"
        if (window.scrollY < 50) {
          links.forEach(l => {
            l.style.color = l.dataset.section === 'about'
              ? 'var(--color-accent)'
              : 'var(--color-text-secondary)';
          });
          return;
        }

        let current = sections[0];
        for (const id of sections) {
          const el = document.getElementById(id);
          if (el && el.offsetTop <= scrollY) current = id;
        }

        links.forEach(l => {
          l.style.color = l.dataset.section === current
            ? 'var(--color-accent)'
            : 'var(--color-text-secondary)';
        });
      }

      window.addEventListener('scroll', updateActiveLink, { passive: true });
      updateActiveLink();
    </script>
  </body>
</html>
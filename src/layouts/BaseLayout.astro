---
import '../styles/global.css';
const { title } = Astro.props;
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Portfolio — Développeur système & graphisme" />
    <title>{title} · Portfolio</title>
  </head>

  <body>
    <div class="layout-wrapper flex flex-col min-h-svh">

      <header
        id="site-header"
        class="sticky top-0 z-40 transition-all duration-300"
      >
        <div class="max-w-5xl mx-auto px-6 md:px-12 h-16 flex items-center justify-between">

          <a
            href="/"
            class="font-mono text-sm font-bold tracking-widest uppercase text-accent"
          >
            <span class="text-text-muted">~/</span>portfolio
          </a>

          <nav class="hidden md:flex items-center gap-8">
            {[
              { label: "À propos", href: "#about"   },
              { label: "Projets",  href: "#projets"  },
              { label: "Contact",  href: "#contact"  },
            ].map(({ label, href }, i) => (
              <a
                href={href}
                data-section={href.slice(1)}
                class="nav-link font-mono text-xs tracking-widest uppercase text-text-secondary hover:text-accent transition-colors duration-200"
              >
                <span class="text-text-muted mr-1">{String(i + 1).padStart(2,'0')}.</span>
                {label}
              </a>
            ))}
          </nav>

          <a
            href="#"
            class="font-mono text-xs text-text-secondary hover:text-accent transition-colors duration-200 hidden md:block"
          >
            GitHub ↗
          </a>
        </div>
        <div class="h-px w-full bg-gradient-to-r from-transparent via-border-base to-transparent"></div>
      </header>

      <main class="flex-grow max-w-5xl mx-auto w-full px-6 md:px-12">
        <slot />
      </main>

      <footer class="max-w-5xl mx-auto w-full px-6 md:px-12 py-10">
        <div class="h-px mb-8 bg-gradient-to-r from-transparent via-border-base to-transparent"></div>
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <span class="font-mono text-xs text-text-muted">© 2026 — Conçu avec Astro & React</span>
          <div class="flex items-center gap-6">
            {[
              { label: 'GitHub',   href: '#' },
              { label: 'LinkedIn', href: '#' },
              { label: 'Mail',     href: '#contact' },
            ].map(({ label, href }) => (
              <a
                href={href}
                class="font-mono text-xs uppercase tracking-widest text-text-secondary hover:text-white transition-colors duration-200"
              >
                {label}
              </a>
            ))}
          </div>
        </div>
      </footer>
    </div>

    <script>
      const header = document.getElementById('site-header') as HTMLElement | null;
      window.addEventListener('scroll', () => {
        if (!header) return;
        if (window.scrollY > 20) {
          header.style.background = 'rgba(6,10,14,0.92)';
          header.style.backdropFilter = 'blur(12px)';
        } else {
          header.style.background = 'transparent';
          header.style.backdropFilter = 'none';
        }
      });

      const links = document.querySelectorAll<HTMLAnchorElement>('.nav-link');

      function updateActiveLink() {
        const sections = ['about', 'projets', 'contact'];
        const scrollY = window.scrollY + 120

        let current = sections[0];
        for (const id of sections) {
          const el = document.getElementById(id);
          if (el && el.offsetTop <= scrollY) current = id;
        }

        links.forEach(l => {
          l.style.color = l.dataset.section === current
            ? 'var(--color-accent)'
            : 'var(--color-text-secondary)';
        });
      }

      window.addEventListener('scroll', updateActiveLink, { passive: true });
      updateActiveLink();
    </script>
  </body>
</html>
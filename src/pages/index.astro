---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero';
import ProjectGallery from '../components/ProjectGallery';
---

<BaseLayout title="Portfolio">

  <Hero client:only="react" />

  <div class="h-px bg-gradient-to-r from-transparent via-border-base to-transparent"></div>

  <ProjectGallery client:only="react" />

  <div class="h-px bg-gradient-to-r from-transparent via-border-base to-transparent"></div>

  <section id="contact" class="py-12">
    <div class="flex items-baseline gap-4 mb-2">
      <span class="font-mono text-xs text-text-muted">03.</span>
      <h2 class="text-3xl font-bold text-text-primary tracking-tight">Contact</h2>
    </div>
    <div
      class="mb-10 h-px"
      style="background: linear-gradient(90deg, var(--color-accent), transparent); width: min(120px,100%)"
    ></div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

      <div>
        <p class="text-sm leading-relaxed text-text-secondary mb-8">
          Étudiant en L3 à la recherche d'un Master pour la rentrée 2026.<br />
          N'hésitez pas à me contacter directement.
        </p>
        <a
          href="mailto:tristan.reig@gmail.com"
          class="inline-flex items-center gap-3 font-mono text-sm font-bold px-6 py-3 rounded-lg bg-accent text-bg-deep transition-all duration-200 hover:-translate-y-px hover:shadow-[0_0_28px_6px_rgba(0,255,156,0.25)]"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          tristan.reig@gmail.com
        </a>
      </div>

      <div class="flex flex-col gap-4">
        <p class="font-mono text-xs text-text-muted uppercase tracking-widest">Curriculum Vitæ</p>

        <div
          class="w-full rounded-xl border overflow-hidden"
          style="border-color: var(--color-border-base); background: var(--color-bg-card); height: 380px;"
        >
          <object
            data="/cv.pdf#toolbar=0&navpanes=0&scrollbar=0&view=FitH"
            type="application/pdf"
            class="w-full h-full"
            aria-label="Aperçu du CV"
          >
            <div class="w-full h-full flex flex-col items-center justify-center gap-3 p-6 text-center">
              <span class="font-mono text-4xl" style="color: var(--color-text-muted)">📄</span>
              <p class="font-mono text-xs" style="color: var(--color-text-muted)">
                Aperçu non disponible dans ce navigateur.
              </p>
            </div>
          </object>
        </div>

        <a
          href="/cv.pdf"
          download
          class="self-start inline-flex items-center gap-2 font-mono text-sm font-medium px-5 py-2.5 rounded-lg border transition-all duration-200 hover:-translate-y-px"
          style="border-color: var(--color-accent); color: var(--color-accent);"
          onmouseover="this.style.background='rgba(0,255,156,0.07)'; this.style.boxShadow='0 0 18px 2px rgba(0,255,156,0.15)';"
          onmouseout="this.style.background='transparent'; this.style.boxShadow='none';"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Télécharger le CV
        </a>
      </div>

    </div>
  </section>

</BaseLayout>